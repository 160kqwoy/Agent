# LLM 配置
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=Qwen3.5-14B
LLM_API_KEY=your_api_key

# 可选配置
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=2048

# 历史记录配置
HISTORY_FILE=chat_history.json
HISTORY_MAX_SIZE=50

# 日志配置
LOGGING_LEVEL=INFO
LOGGING_FILE=agent.log

# Agent 配置
AGENT_MAX_ITERATIONS=5
AGENT_HISTORY_LENGTH=10

# 天气 API 配置（OpenWeatherMap）
# 请访问 https://openweathermap.org/api 免费注册获取 API Key
OPENWEATHER_API_KEY=your_openweather_api_key

# 新闻 API 配置（NewsAPI）
# 请访问 https://newsapi.org/ 免费注册获取 API Key
NEWSAPI_KEY=your_newsapi_key

# 图片生成 API 配置（OpenAI DALL-E）
# 请访问 https://platform.openai.com/ 获取 API Key
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com
